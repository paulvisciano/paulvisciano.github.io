# Transcriber Agent — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# WhatsApp target (your phone number or chat ID)
WHATSAPP_TARGET="+XXXXXXXXXXX"

# Optional: Override whisper model
# WHISPER_MODEL="medium"

# Optional: Custom archive base (defaults to ~/Personal/paulvisciano.github.io/memory/raw/)
# ARCHIVE_BASE="$HOME/Personal/paulvisciano.github.io/memory/raw/"
